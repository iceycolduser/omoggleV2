# nginx reverse proxy for omoggle v2 on netcup arm vps.
# expects Node app on 127.0.0.1:8080 (see ecosystem.config.cjs).
# put under /etc/nginx/sites-available/omoggle and symlink to sites-enabled.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.tld www.your-domain.tld;

    # certbot --nginx will populate the TLS server below.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name your-domain.tld www.your-domain.tld;

    ssl_certificate     /etc/letsencrypt/live/your-domain.tld/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.tld/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # webcam APIs require a secure context (https) on non-localhost origins.
    add_header Permissions-Policy "camera=(self), microphone=(self)";
    add_header Referrer-Policy   "no-referrer";
    add_header X-Frame-Options   "DENY";
    add_header X-Content-Type-Options "nosniff";

    client_max_body_size 1m;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_read_timeout 60s;
    }

    # socket.io polling fallback + websocket upgrade
    location /socket.io/ {
        proxy_pass         http://127.0.0.1:8080/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_read_timeout 600s;
    }
}
